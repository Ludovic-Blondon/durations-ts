{
  "name": "durations-ts",
  "version": "0.1.0",
  "description": "Type-safe duration parsing with compile-time validation. Parse '2h 30m' to milliseconds with zero dependencies.",
  "author": "Ludovic Blondon",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "duration",
    "parse",
    "time",
    "milliseconds",
    "typescript",
    "type-safe",
    "template-literal-types",
    "humanize",
    "zero-dependency"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:types": "vitest typecheck",
    "lint": "eslint src/ tests/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "bench": "tsx benchmarks/bench.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run test && npm run build",
    "ci": "npm run lint && npm run format:check && npm run typecheck && npm run test:coverage && npm run build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "ms": "^2.1.3",
    "parse-duration": "^2.1.0",
    "prettier": "^3.0.0",
    "tinybench": "^3.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
